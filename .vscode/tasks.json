{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++ compilar com Eigen",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-std=c++17",
                "-g",
                "${file}",
                "-I",
                "/usr/include/eigen3",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Tarefa gerada pelo usuário para incluir a Eigen no Ubuntu."
        }
    ],
    "version": "2.0.0"
}